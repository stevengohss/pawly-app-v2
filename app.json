{
  "expo": {
    "name": "Pawly V2",
    "slug": "pawly-v2",
    "version": "2.0.1",
    "orientation": "portrait",
    "scheme": "pawly-v2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF9F6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
